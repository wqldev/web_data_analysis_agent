{
  "mcpServers": {
    "mysql-local": {
      "command": "${workspaceFolder}/scripts/run-mcp.cmd",
      "args": [
        "server.py"
      ],
      "env": {
        "MYSQL_HOST": "localhost",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "123456",
        "MYSQL_DATABASE": "mysql_dataset_test",
        "MYSQL_ALLOW_WRITES": "false"
      }
    },
    "task-board": {
      "command": "${workspaceFolder}/scripts/run-mcp.cmd",
      "args": [
        "task_board_server.py"
      ],
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8",
        "TASK_BOARD_DIR": "${workspaceFolder}/boards"
      }
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": [
        "serve",
        "--mcp",
        "--path",
        "C:\\Users\\10512\\Desktop\\my_first_agent"
      ]
    }
  }
}
